{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "globalEnv": ["FIGMA_TOKEN", "GITHUB_SPONSORS_TOKEN", "RENOUN_DEBUG"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:browser": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
